PORT=4000
NODE_ENV=production
# The deployed frontend's origin (Vercel URL) — must be exact, no trailing slash.
CORS_ORIGIN=

# OpenAI Platform → API Keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Rows sent to OpenAI per batch call — see ARCHITECTURE.md "Guardrails" for why
# this is bounded rather than sending the whole CSV in one prompt.
AI_BATCH_SIZE=25
